# Semantic Text Retrieval Notebook

## 1. Install & Import Section
```python
!pip install sentence-transformers gensim

import pandas as pd
import numpy as np
from sentence_transformers import SentenceTransformer
from gensim.models import KeyedVectors
from sklearn.metrics.pairwise import cosine_similarity
```

## 2. Dataset Section
```python
# Sample dataset with 250 sentences across 8 categories
categories = {
    'Electronics': ["Smartphone with high resolution camera.", ...],  # Add more sentences
    'Fashion': ["Latest trends in clothing.", ...],  # Add more sentences
    'Food': ["Healthy recipes for a balanced diet.", ...],  # Add more sentences
    'Health': ["Tips for maintaining mental health.", ...],  # Add more sentences
    'Travel': ["Best places to visit in 2023.", ...],  # Add more sentences
    'Finance': ["Investment strategies for beginners.", ...],  # Add more sentences
    'Home': ["Home improvement tips.", ...],  # Add more sentences
    'Education': ["Online learning resources.", ...]  # Add more sentences
}

# Create a DataFrame
data = []
for category, sentences in categories.items():
    data.extend([(category, s) for s in sentences])

df = pd.DataFrame(data, columns=['Category', 'Sentence'])
```

## 3. Text Preprocessing
```python
# Function to tokenize sentences
from nltk.tokenize import word_tokenize
import nltk
nltk.download('punkt')

def preprocess(text):
    return word_tokenize(text.lower())

# Apply preprocessing
df['Tokens'] = df['Sentence'].apply(preprocess)
```

## 4. GloVe Embeddings
```python
# Load GloVe embeddings
glove_model = KeyedVectors.load_word2vec_format('glove-wiki-gigaword-100.txt', binary=False)
```

## 5. Word2Vec
```python
# Train Word2Vec model
from gensim.models import Word2Vec
model_w2v = Word2Vec(sentences=df['Tokens'], vector_size=100, window=5, min_count=1)
```

## 6. Sentence-BERT Embeddings
```python
# Load Sentence-BERT model
model_sentence_bert = SentenceTransformer('all-MiniLM-L6-v2')

def get_sentence_embeddings(sentences):
    return model_sentence_bert.encode(sentences)

# Get embeddings
embeddings = get_sentence_embeddings(df['Sentence'].tolist())
```

## 7. Retrieval Function
```python
def retrieve_similar_sentences(query, top_k=5):
    query_embedding = get_sentence_embeddings([query])
    similarities = cosine_similarity(query_embedding, embeddings)
    similar_indices = np.argsort(similarities[0])[::-1][:top_k]
    return df.iloc[similar_indices]
```

## 8. Similarity Tables for 5 Example Queries
```python
queries = ["Best smartphone in 2023", "Fashion trends to watch", "Healthy meals to prepare", "Mental health awareness", "Places to explore this summer"]
results = {}
for query in queries:
    results[query] = retrieve_similar_sentences(query)
# Display results
results
```

