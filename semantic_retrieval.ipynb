# ---- 3. Text Preprocessing ----
def preprocess(text):
    text = text.lower()
    text = re.sub(r'[^a-z0-9\s]', '', text)
    return text.split()

print('Original:', dataset[0])
print('Tokenized:', preprocess(dataset[0]))

# ---- 4A. GloVe (Pre-trained, 100d) ----
print('\nLoading GloVe embeddings...')
glove_model = api.load('glove-wiki-gigaword-100')
print('GloVe loaded!')

def get_avg_embedding(tokens, model, dim=100):
    vecs = [model[w] for w in tokens if w in model]
    if not vecs:
        return np.zeros(dim)
    return np.mean(vecs, axis=0)

glove_embeddings = np.array([
    get_avg_embedding(preprocess(s), glove_model) for s in dataset
])
print(f'GloVe embeddings shape: {glove_embeddings.shape}')

# ---- 4B. Word2Vec (Trained on our corpus) ----
tokenized_corpus = [preprocess(s) for s in dataset]
w2v_model = Word2Vec(sentences=tokenized_corpus, vector_size=100, window=5,
                     min_count=1, workers=4, epochs=100, seed=42)
print(f'Word2Vec trained - Vocab size: {len(w2v_model.wv)}')

w2v_embeddings = np.array([
    get_avg_embedding(tokens, w2v_model.wv) for tokens in tokenized_corpus
])
print(f'Word2Vec embeddings shape: {w2v_embeddings.shape}')

# ---- 4C. Sentence-BERT ----
print('\nLoading Sentence-BERT model...')
sbert_model = SentenceTransformer('all-MiniLM-L6-v2')
sbert_embeddings = sbert_model.encode(dataset, show_progress_bar=True,
                                       normalize_embeddings=True)
print(f'SBERT embeddings shape: {sbert_embeddings.shape}')

# ---- 5. Retrieval Function ----
def retrieve_top_k(query, dataset, embeddings, model_type, k=5,
                   word_model=None, sbert_model_obj=None):
    if model_type == 'sbert':
        q_emb = sbert_model_obj.encode([query], normalize_embeddings=True)
    else:
        q_tokens = preprocess(query)
        dim = embeddings.shape[1]
        q_emb = get_avg_embedding(q_tokens, word_model, dim).reshape(1, -1)
    sims = cosine_similarity(q_emb, embeddings)[0]
    top_indices = np.argsort(sims)[::-1][:k]
    results = []
    for idx in top_indices:
        results.append({
            'rank': len(results) + 1,
            'sentence': dataset[idx],
            'similarity': round(float(sims[idx]), 4)
        })
    return results

# Quick test
test_results = retrieve_top_k('I need headphones for music',
                               dataset, sbert_embeddings, 'sbert',
                               sbert_model_obj=sbert_model)
print('\nTest query: "I need headphones for music"')
for r in test_results:
    print(f"  #{r['rank']} (sim={r['similarity']:.4f}): {r['sentence'][:80]}")

