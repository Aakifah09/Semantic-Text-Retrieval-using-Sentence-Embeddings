def auto_relevance(sentence, keywords):
    s_lower = sentence.lower()
    return any(kw in s_lower for kw in keywords)

print(f"{'Query':<40} {'Method':<10} {'P@1':>5} {'P@3':>5} {'P@5':>5}")
print('-' * 75)

method_scores = defaultdict(lambda: {'p1': [], 'p3': [], 'p5': []})

for eq in evaluation_queries:
    q = eq['query']
    kws = eq['relevant_keywords']
    for method_name, embs, m_type, wm in [
        ('GloVe', glove_embeddings, 'glove', glove_model),
        ('Word2Vec', w2v_embeddings, 'w2v', w2v_model.wv),
        ('SBERT', sbert_embeddings, 'sbert', None),
    ]:
        results = retrieve_top_k(q, dataset, embs, m_type,
                                 k=5, word_model=wm, sbert_model_obj=sbert_model)
        relevances = [auto_relevance(r['sentence'], kws) for r in results]
        p1 = sum(relevances[:1]) / 1
        p3 = sum(relevances[:3]) / 3
        p5 = sum(relevances[:5]) / 5
        method_scores[method_name]['p1'].append(p1)
        method_scores[method_name]['p3'].append(p3)
        method_scores[method_name]['p5'].append(p5)
        print(f'{q:<40} {method_name:<10} {p1:>5.2f} {p3:>5.2f} {p5:>5.2f}')
    print()

